# ================================================
# Adapter System Configuration
# ================================================
# Comments MUST be on their own line, NOT inline!

# Application
APP_NAME='Adapter System'
APP_VERSION=1.0.0
ENVIRONMENT=development

# Customer Instance Identification
CUSTOMER_ID=acme_corp
INSTANCE_ID=acme-dev-local

# Database (prefix: MONGO_)
MONGO_URL=mongodb://localhost:27017
MONGO_DB_NAME=asset_management
MONGO_MAX_POOL_SIZE=10
MONGO_MIN_POOL_SIZE=5

# Celery (prefix: CELERY_)
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
CELERY_RESULT_BACKEND=rpc://

# Redis (prefix: REDIS_)
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10

# API (prefix: API_)
API_HOST=0.0.0.0
API_PORT=8080
API_DEBUG=false
API_CORS_ORIGINS=["http://localhost:5173"]
API_JWT_SECRET_KEY=change-me-to-a-random-32-char-string
API_JWT_ALGORITHM=HS256
API_JWT_EXPIRATION_MINUTES=60
API_RATE_LIMIT_ENABLED=true
API_LIMIT_PER_MINUTE=100

# HTTP Client (prefix: ADAPTER_)
# Note: Don't put adapter credentials here!
# These are just HTTP client defaults
ADAPTER_DEFAULT_TIMEOUT=30
ADAPTER_DEFAULT_MAX_RETRIES=3
ADAPTER_DEFAULT_RETRY_WAIT=5

# Logging (prefix: LOG_)
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/var/log/adapter-system.log